<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{ site.name }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Serif:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <canvas id="topographic-bg" aria-hidden="true"></canvas>

    <!-- NAV -->
    <nav>
      <a class="nav-name" href="#">{{ site.name }}</a>
      <div class="nav-links">
        <a href="https://ctx-0.github.io/notes/">notes</a>
        <button class="theme-open" type="button" aria-haspopup="dialog" aria-label="Choose theme">
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <circle cx="8" cy="8" r="3.1"></circle>
            <path d="M8 1.5v1.3M8 13.2v1.3M1.5 8h1.3M13.2 8h1.3M3.4 3.4l.9.9M11.7 11.7l.9.9M12.6 3.4l-.9.9M4.3 11.7l-.9.9"></path>
          </svg>
        </button>
      </div>
    </nav>

    <dialog class="theme-dialog" aria-labelledby="theme-title">
      <div class="theme-dialog-head">
        <h2 id="theme-title">Choose a field</h2>
        <button class="theme-close" type="button">close</button>
      </div>
      <div class="theme-groups">
        <div class="theme-group">
          <p class="theme-group-title">Light fields</p>
          <div class="theme-options">
            <button class="theme-option" type="button" data-theme="paper-green">
              <span class="theme-swatch"></span>
              <span><strong>Paper green</strong><small>classic</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="silicon-sage">
              <span class="theme-swatch"></span>
              <span><strong>Silicon sage</strong><small>quiet technical</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="warm-mineral">
              <span class="theme-swatch"></span>
              <span><strong>Warm mineral</strong><small>soft neutral</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="wafer-grey">
              <span class="theme-swatch"></span>
              <span><strong>Cool wafer grey</strong><small>neutral silicon</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="gold-paper">
              <span class="theme-swatch"></span>
              <span><strong>Muted gold paper</strong><small>current</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="lavender-silicon">
              <span class="theme-swatch"></span>
              <span><strong>Lavender silicon</strong><small>cool spectral</small></span>
            </button>
          </div>
        </div>
        <div class="theme-group">
          <p class="theme-group-title">Dark fields</p>
          <div class="theme-options">
            <button class="theme-option" type="button" data-theme="dark-silicon">
              <span class="theme-swatch"></span>
              <span><strong>Dark silicon</strong><small>recommended dark</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="graphite-silicon">
              <span class="theme-swatch"></span>
              <span><strong>Graphite silicon</strong><small>neutral dark</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="blue-wafer">
              <span class="theme-swatch"></span>
              <span><strong>Blue-black wafer</strong><small>cool dark</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="olive-terminal">
              <span class="theme-swatch"></span>
              <span><strong>Olive terminal</strong><small>earthy dark</small></span>
            </button>
            <button class="theme-option" type="button" data-theme="charcoal-violet">
              <span class="theme-swatch"></span>
              <span><strong>Charcoal violet</strong><small>spectral dark</small></span>
            </button>
          </div>
        </div>
        <div class="theme-group">
          <p class="theme-group-title">Motion</p>
          <label class="theme-toggle">
            <span>Background animation</span>
            <input class="background-toggle" type="checkbox" checked />
          </label>
          <label class="theme-toggle">
            <span>Hero dither field</span>
            <input class="hero-dither-toggle" type="checkbox" checked />
          </label>
        </div>
      </div>
    </dialog>

    <!-- MAIN -->
    <main>
      <section class="top-section" aria-label="Hero and work">
        <!-- HERO -->
        <div class="hero">
          <p class="hero-name rise r1 diffuse-text" data-diffuse data-diffuse-delay="120">{{ site.name }}</p>
          <p class="hero-bio rise r2 diffuse-text" data-diffuse data-diffuse-delay="360">
            {{ site.bio_intro }} {{ site.bio_highlight }}. {{ site.bio_rest }}
          </p>
          <div class="hero-contact rise r3">
            {% if site.email is defined and site.email %}
            <a href="mailto:{{ site.email }}">{{ site.email }}</a>
            {% endif %}
            {% for link in site.links %}
            <a href="{{ link.url }}"{% if link.url.startswith("http") %} target="_blank" rel="noopener"{% endif %}>{{ link.label }}</a>
            {% endfor %}
          </div>
        </div>

        <section id="work" class="work-content reveal">
          <!-- WRITING -->
          {% if writing %}
          <div id="writing" class="plain-index work-block">
        {% for item in writing %}
        <div class="blog-row">
            {% if item.url is defined and item.url %}
            <p class="blog-title"><a href="{{ item.url }}"{% if item.url.startswith("http") %} target="_blank" rel="noopener"{% endif %}>{{ item.title }}</a></p>
            {% else %}
            <p class="blog-title">{{ item.title }}</p>
            {% endif %}
            {% if item.excerpt is defined and item.excerpt %}
            <p class="blog-excerpt">{{ item.excerpt }}</p>
            {% endif %}
          {% if item.date is defined and item.date %}
          <p class="blog-date">{{ item.date }}</p>
          {% endif %}
        </div>
        {% endfor %}
          </div>
          {% endif %}

          <!-- PROJECTS -->
          <div id="projects" class="plain-index work-block">
        {% for project in projects %}
        <p class="proj-row{% if project.stub is defined and project.stub %} is-stub{% endif %}">
          <span class="proj-name-wrap">
            <span class="proj-name">
              {% if project.url is defined and project.url %}
              <a href="{{ project.url }}"{% if project.url.startswith("http") %} target="_blank" rel="noopener"{% endif %}>{{ project.name }}</a>
              {% else %}
              {{ project.name }}
              {% endif %}
            </span>
          </span>{% if project.stub is defined and project.stub %}<span class="stub-label">stub</span>{% endif %}{% if project.description is defined and project.description %}<span class="proj-desc">{{ project.description }}</span>{% endif %}
        </p>
        {% endfor %}
          </div>
        </section>
      </section>

      <section class="context-section" aria-label="Research, reading, and quotes">

        <!-- READING -->
        <section id="reading" class="reveal">
        <p class="sec-eyebrow">read recently</p>
        <p class="column-subtitle">some recent good reads</p>

        {% set reading = namespace(count=0) %}
        {% if reading_entries %}
        <div class="time-chunk">
          {% for entry in reading_entries %}
          <a class="read-row{% if reading.count >= 7 %} mobile-reading-extra{% endif %}" href="{{ entry.url }}"{% if entry.url.startswith("http") %} target="_blank" rel="noopener"{% endif %}>
            <span class="read-title">{{ entry.title }}</span>
          </a>
          {% set reading.count = reading.count + 1 %}
        {% endfor %}
        </div>
        <button class="reading-toggle" type="button" aria-expanded="false">show full reading list</button>
        {% else %}
        <p class="read-empty">Nothing here yet.</p>
        {% endif %}
        </section>

        <!-- QUOTES -->
        <section id="quotes" class="reveal">
          {% if quotes %}
          <div class="quote-list">
            {% for quote in quotes %}
            <p class="quote-item">
              {{ quote.text }}
              {% if quote.source is defined and quote.source %}
              <span class="quote-source">{{ quote.source }}</span>
              {% endif %}
            </p>
            {% endfor %}
          </div>
          {% else %}
          <p class="quote-empty">No quotes yet.</p>
          {% endif %}
        </section>
      </section>
    </main>

    <footer>
      <canvas id="footer-ribbons" aria-hidden="true"></canvas>
      <div class="footer-body">
        <p class="footer-kicker">end of current context</p>
        <p class="footer-meta">{{ site.name }} / notes and signals</p>
      </div>
    </footer>

    <script src="app.js" defer></script>
  </body>
</html>
